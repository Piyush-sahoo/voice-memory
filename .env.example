# ==========================================
# VOICE AGENT PROMPT OPTIMIZER - ENV CONFIG
# ==========================================

# ─── OpenAI (for baseline inference + live optimization) ───
OPENAI_API_KEY=sk-...

# ─── LiveKit Cloud (for live call demo) ───
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIabc123...
LIVEKIT_API_SECRET=secret...

# ─── Deepgram (STT for live calls) ───
DEEPGRAM_API_KEY=...

# ─── TTS Provider ───
TTS_PROVIDER=openai

# ─── Vobiz SIP Trunk (for outbound calls) ───
VOBIZ_SIP_DOMAIN=your_sip_domain.sip.vobiz.ai
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX
OUTBOUND_TRUNK_ID=ST_xxx

# ─── Call Transfer ───
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX

# ─── OpenEnv Server (for demo script) ───
OPENENV_URL=http://localhost:8000
